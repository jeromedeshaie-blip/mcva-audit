# MCVA Local Crawler — Config .env
# Copier ce fichier vers .env et remplir les valeurs

# API MCVA Audit (Vercel prod)
MCVA_API_URL=https://mcva-audit.vercel.app
MCVA_API_KEY=mcva_live_xxxxxxxxxxxxxxxxxxxxxx_REPLACE_ME

# Ollama local
OLLAMA_ENDPOINT=http://localhost:11434
MCVA_LOCAL_LLM=gemma4:31b
# Bascule rapide si tu veux tester : MCVA_LOCAL_LLM=gemma4:26b

# Crawl config
MAX_PAGES_PER_CRAWL=10
CRAWL_TIMEOUT_SECONDS=30
USER_AGENT=MCVAAuditBot/3.0 (+https://mcva.ch/audit)

# Output
OUTPUT_DIR=./output
CACHE_DIR=./cache
