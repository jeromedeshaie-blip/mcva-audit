# ============================================================
# MCVA Audit Platform — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.

# --- Provider Configuration (Palier 1 = free/direct_ai, Palier 2 = semrush/qwairy) ---
SEO_PROVIDER=free
GEO_PROVIDER=direct_ai

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- LLM (scoring CORE-EEAT/CITE) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- GEO Palier 1 (optional — only needed for DirectAIGeoProvider) ---
OPENAI_API_KEY=sk-...
# PERPLEXITY_API_KEY=pplx-...
# GOOGLE_AI_API_KEY=...

# --- SEO Palier 1 (optional — improves PageSpeed rate limits) ---
# PAGESPEED_API_KEY=...

# --- Palier 2 (not needed during construction) ---
# SEMRUSH_API_KEY=...
# QWAIRY_API_KEY=...

# --- Inngest ---
INNGEST_EVENT_KEY=your-event-key
INNGEST_SIGNING_KEY=your-signing-key
